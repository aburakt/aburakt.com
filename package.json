{
  "name": "aburakt.com",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @aburakt/web dev",
    "dev:api": "pnpm --filter @aburakt/api dev",
    "build": "pnpm --filter @aburakt/web build",
    "build:api": "pnpm --filter @aburakt/api deploy",
    "typecheck": "pnpm -r typecheck",
    "preview": "pnpm --filter @aburakt/web preview"
  }
}

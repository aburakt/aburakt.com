{
  "name": "aburakt.com",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun --filter @aburakt/web dev",
    "dev:api": "bun --filter @aburakt/api dev",
    "build": "bun --filter @aburakt/web build",
    "build:api": "bun --filter @aburakt/api deploy",
    "typecheck": "bun --filter '*' typecheck",
    "preview": "bun --filter @aburakt/web preview",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  }
}

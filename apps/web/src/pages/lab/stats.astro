---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import Dashboard from '@/components/react/Dashboard'
import { getLocaleFromUrl } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
const prefix = locale === 'en' ? '/en' : ''
---

<PortfolioLayout title={locale === 'tr' ? 'İstatistikler' : 'Stats'} zone="dashboard">
  <Container class="mt-16 sm:mt-24" data-section="stats">
    <div class="mb-8">
      <a href={`${prefix}/lab`} class="text-xs text-cyan-500 hover:text-cyan-400">
        ← lab/
      </a>
    </div>
    <div class="flex items-center gap-2 text-xs text-green-700 mb-4">
      <span class="text-green-500">$</span>
      <span class="text-cyan-600">htop --user aburakt</span>
    </div>
    <h1 class="text-xl font-bold text-cyan-400 text-glow-cyan sm:text-2xl">
      {locale === 'tr' ? 'İstatistikler' : 'Statistics'}
    </h1>
    <p class="mt-3 text-xs text-green-600 mb-8">
      {locale === 'tr'
        ? 'Yazma ve vim istatistiklerinizi takip edin.'
        : 'Track your typing and vim statistics.'}
    </p>
    <Dashboard locale={locale} client:only="react" />
  </Container>
</PortfolioLayout>

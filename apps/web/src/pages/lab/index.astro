---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import StatsOverview from '@/components/react/StatsOverview'
import { getLocaleFromUrl, t } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
const prefix = locale === 'en' ? '/en' : ''
---

<PortfolioLayout title="Lab">
  <Container class="mt-16 sm:mt-24" data-section="lab-hub">
    <div class="flex items-center gap-2 text-xs text-green-700 mb-8">
      <span class="text-green-500">$</span>
      <span>ls ~/lab/</span>
    </div>

    <h1 class="text-xl font-bold text-cyan-400 text-glow-cyan sm:text-2xl">
      Lab
    </h1>
    <p class="mt-3 text-xs text-green-600">
      {locale === 'tr'
        ? 'Vim ve yazma becerilerini geliştir, ilerlemenizi takip et.'
        : 'Sharpen your vim and typing skills, track your progress.'}
    </p>

    <div class="mt-12 space-y-6">
      <!-- Vim card -->
      <a
        href={`${prefix}/lab/vim`}
        class="group block rounded-lg border border-cyan-900/30 bg-cyan-950/10 p-6 transition hover:border-cyan-500/50 hover:bg-cyan-950/20"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="text-amber-400 text-xs">drwxr-xr-x</span>
            <span class="text-sm font-semibold text-cyan-400 text-glow-cyan">vim/</span>
          </div>
          <span class="text-xs text-green-800 group-hover:text-cyan-500 transition">cd vim/ ></span>
        </div>
        <p class="mt-3 text-xs text-green-600">
          {locale === 'tr'
            ? '70+ komut cheatsheet · 20+ interaktif alıştırma · 5 oyun'
            : '70+ command cheatsheet · 20+ interactive exercises · 5 games'}
        </p>
      </a>

      <!-- Typing card -->
      <a
        href={`${prefix}/lab/typing`}
        class="group block rounded-lg border border-amber-900/30 bg-amber-950/10 p-6 transition hover:border-amber-500/50 hover:bg-amber-950/20"
      >
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-3">
            <span class="text-cyan-400 text-xs">drwxr-xr-x</span>
            <span class="text-sm font-semibold text-amber-400 text-glow-amber">typing/</span>
          </div>
          <span class="text-xs text-green-800 group-hover:text-amber-500 transition">cd typing/ ></span>
        </div>
        <p class="mt-3 text-xs text-green-600">
          {locale === 'tr'
            ? '8 yapılandırılmış ders · yazma testi · hız yarışı · 3 oyun'
            : '8 structured lessons · typing test · speed challenge · 3 games'}
        </p>
      </a>

      <!-- Stats section -->
      <div class="rounded-lg border border-green-900/30 bg-green-950/10 p-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-green-500 text-xs">-rw-r--r--</span>
          <span class="text-sm font-semibold text-green-400">stats</span>
        </div>
        <StatsOverview locale={locale} client:only="react" />
      </div>
    </div>
  </Container>
</PortfolioLayout>

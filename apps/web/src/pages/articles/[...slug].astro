---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const articles = await getCollection('articles')
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await render(article)
---

<PortfolioLayout title={article.data.title}>
  <Container class="mt-16 sm:mt-24" data-section="article">
    <div class="mb-8">
      <a href="/articles" class="text-xs text-green-500 hover:text-green-400">
        ← articles/
      </a>
    </div>

    <div class="flex items-center gap-2 text-xs text-green-700 mb-6">
      <span class="text-green-500">$</span>
      <span>cat ~/articles/{article.id}.md</span>
    </div>

    <article class="max-w-2xl">
      <header class="mb-8">
        <div class="flex items-center gap-3 text-xs text-green-700">
          <span class="text-amber-400">{article.data.date}</span>
          <span class="text-green-800">—</span>
          <span class="text-green-600">{article.data.author}</span>
        </div>
        <h1 class="mt-3 text-xl font-bold text-green-400 text-glow sm:text-2xl leading-tight">
          {article.data.title}
        </h1>
        <p class="mt-3 text-xs text-green-600">
          {article.data.description}
        </p>
      </header>

      <div class="prose-terminal space-y-4 text-sm leading-relaxed text-green-600">
        <Content />
      </div>
    </article>
  </Container>
</PortfolioLayout>

<style is:global>
  .prose-terminal p {
    margin-bottom: 1rem;
  }
  .prose-terminal a {
    color: #4ade80;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: #166534;
    transition: text-decoration-color 0.2s;
  }
  .prose-terminal a:hover {
    text-decoration-color: #4ade80;
    text-shadow: 0 0 8px rgba(34, 197, 94, 0.6);
  }
  .prose-terminal code {
    color: #86efac;
    background: rgba(34, 197, 94, 0.1);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.8125rem;
  }
</style>

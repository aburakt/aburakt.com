---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import { getCollection } from 'astro:content'

const articles = (await getCollection('articles')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
---

<PortfolioLayout title="Articles">
  <Container class="mt-16 sm:mt-24" data-section="articles">
    <div class="flex items-center gap-2 text-xs text-green-700 mb-8">
      <span class="text-green-500">$</span>
      <span class="text-cyan-600">ls -lt ~/articles/</span>
    </div>

    <h1 class="text-xl font-bold text-cyan-400 text-glow-cyan sm:text-2xl">
      Articles
    </h1>
    <p class="mt-3 text-xs text-green-600">
      Yazılım geliştirme, mimari kararlar ve araçlar hakkında yazılar.
    </p>

    <div class="mt-12 space-y-4">
      {articles.map((article) => (
        <a
          href={`/articles/${article.id}`}
          class="group block rounded-lg border border-green-900/30 bg-green-950/20 p-5 transition hover:border-green-500/50 hover:bg-green-950/40"
        >
          <div class="flex items-center gap-3 text-xs text-green-700">
            <span class="text-amber-400">{article.data.date}</span>
            <span class="text-green-800">—</span>
            <span class="text-green-600">{article.data.author}</span>
          </div>
          <h2 class="mt-2 text-sm font-semibold text-cyan-400 group-hover:text-glow-cyan">
            {article.data.title}
          </h2>
          <p class="mt-1 text-xs text-green-600">
            {article.data.description}
          </p>
          <div class="mt-3 text-xs text-green-700 group-hover:text-green-500 transition">
            > cat {article.id}.md
          </div>
        </a>
      ))}
    </div>
  </Container>
</PortfolioLayout>

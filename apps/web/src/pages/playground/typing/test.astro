---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import TypingTest from '@/components/react/typing/TypingTest'
import { getLocaleFromUrl } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
const prefix = locale === 'en' ? '/en' : ''
---

<PortfolioLayout title={locale === 'tr' ? 'Yazma Testi' : 'Typing Test'} zone="typing">
  <Container class="mt-16 sm:mt-24" data-section="typing-test">
    <div class="mb-12 max-w-2xl">
      <a href={`${prefix}/playground/typing`} class="text-xs text-amber-500 hover:text-amber-400">
        ← {locale === 'tr' ? 'typing/' : 'typing/'}
      </a>
      <div class="flex items-center gap-2 text-xs text-green-700 mt-4 mb-4">
        <span class="text-green-500">$</span>
        <span class="text-amber-600">./typing-test --run</span>
      </div>
      <h1 class="text-xl font-bold text-amber-400 text-glow-amber sm:text-2xl">
        {locale === 'tr' ? 'Yazma Testi' : 'Typing Test'}
      </h1>
      <p class="mt-3 text-xs text-green-600">
        {locale === 'tr'
          ? 'WPM hızınızı ve doğruluğunuzu ölçün. Farklı süreler seçebilirsiniz.'
          : 'Measure your WPM speed and accuracy. Choose different durations.'}
      </p>
    </div>

    <TypingTest locale={locale} client:only="react" />
  </Container>
</PortfolioLayout>

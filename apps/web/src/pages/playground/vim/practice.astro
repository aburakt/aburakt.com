---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import VimExercises from '@/components/react/vim/VimExercises'
import { getLocaleFromUrl } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
---

<PortfolioLayout title={locale === 'tr' ? 'Vim Alıştırmaları' : 'Vim Exercises'} zone="vim">
  <Container class="mt-16 sm:mt-24" data-section="vim-practice">
    <div class="mb-12 max-w-2xl">
      <a href={locale === 'tr' ? '/playground/vim' : '/en/playground/vim'} class="text-xs text-cyan-500 hover:text-cyan-400">
        ← {locale === 'tr' ? 'vim/' : 'vim/'}
      </a>
      <div class="flex items-center gap-2 text-xs text-green-700 mt-4 mb-4">
        <span class="text-green-500">$</span>
        <span class="text-cyan-600">./vim-practice --interactive</span>
      </div>
      <h1 class="text-xl font-bold text-cyan-400 text-glow-cyan sm:text-2xl">
        {locale === 'tr' ? 'İnteraktif Alıştırmalar' : 'Interactive Exercises'}
      </h1>
      <p class="mt-3 text-xs text-green-600">
        {locale === 'tr'
          ? 'Görev tabanlı alıştırmalarla vim komutlarını pratik yapın. Editörde vim modu aktif.'
          : 'Practice vim commands with task-based exercises. Vim mode is active in the editor.'}
      </p>
    </div>
    <VimExercises locale={locale} client:only="react" />
  </Container>
</PortfolioLayout>

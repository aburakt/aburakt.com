---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import VimCheatsheet from '@/components/react/vim/VimCheatsheet'
import { getLocaleFromUrl } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
---

<PortfolioLayout title={locale === 'tr' ? 'Vim Hareketleri & Cheatsheet' : 'Vim Motions & Cheatsheet'} zone="vim">
  <Container class="mt-16 sm:mt-24" data-section="vim-motions">
    <div class="mb-12 max-w-2xl">
      <a href={locale === 'tr' ? '/playground/vim' : '/en/playground/vim'} class="text-xs text-cyan-500 hover:text-cyan-400">
        ← {locale === 'tr' ? 'vim/' : 'vim/'}
      </a>
      <div class="flex items-center gap-2 text-xs text-green-700 mt-4 mb-4">
        <span class="text-green-500">$</span>
        <span class="text-cyan-600">./vim-motions --cheatsheet</span>
      </div>
      <h1 class="text-xl font-bold text-cyan-400 text-glow-cyan sm:text-2xl">
        {locale === 'tr' ? 'Vim Hareketleri & Cheatsheet' : 'Vim Motions & Cheatsheet'}
      </h1>
      <p class="mt-3 text-xs text-green-600">
        {locale === 'tr'
          ? 'Tüm vim komutlarını kategorilere göre keşfedin. Fuzzy arama ile hızlıca bulun.'
          : 'Explore all vim commands by category. Find quickly with fuzzy search.'}
      </p>
    </div>
    <VimCheatsheet locale={locale} client:load />
  </Container>
</PortfolioLayout>

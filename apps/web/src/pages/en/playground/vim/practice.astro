---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import VimExercises from '@/components/react/vim/VimExercises'
import { getLocaleFromUrl } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
---

<PortfolioLayout title={locale === 'tr' ? 'Vim Alıştırmaları' : 'Vim Exercises'}>
  <Container class="mt-16 sm:mt-24" data-section="vim-practice">
    <div class="mb-12 max-w-2xl">
      <a href={locale === 'tr' ? '/playground/vim' : '/en/playground/vim'} class="text-sm text-primary-500 hover:text-primary-400">
        ← {locale === 'tr' ? 'Vim Merkezi' : 'Vim Center'}
      </a>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-zinc-800 sm:text-5xl dark:text-zinc-100">
        {locale === 'tr' ? 'İnteraktif Alıştırmalar' : 'Interactive Exercises'}
      </h1>
      <p class="mt-4 text-base text-zinc-600 dark:text-zinc-400">
        {locale === 'tr'
          ? 'Görev tabanlı alıştırmalarla vim komutlarını pratik yapın. Editörde vim modu aktif.'
          : 'Practice vim commands with task-based exercises. Vim mode is active in the editor.'}
      </p>
    </div>
    <VimExercises locale={locale} client:only="react" />
  </Container>
</PortfolioLayout>

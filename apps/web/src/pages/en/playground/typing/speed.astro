---
import PortfolioLayout from '@/layouts/PortfolioLayout.astro'
import Container from '@/components/astro/Container.astro'
import SpeedChallenge from '@/components/react/typing/SpeedChallenge'
import { getLocaleFromUrl } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
const prefix = locale === 'en' ? '/en' : ''
---

<PortfolioLayout title={locale === 'tr' ? 'Hız Yarışı' : 'Speed Challenge'}>
  <Container class="mt-16 sm:mt-24" data-section="typing-speed">
    <div class="mb-12 max-w-2xl">
      <a href={`${prefix}/playground/typing`} class="text-xs text-green-500 hover:text-green-400">
        ← {locale === 'tr' ? 'typing/' : 'typing/'}
      </a>
      <div class="flex items-center gap-2 text-xs text-green-700 mt-4 mb-4">
        <span class="text-green-500">$</span>
        <span>./speed-challenge --race</span>
      </div>
      <h1 class="text-xl font-bold text-green-400 text-glow sm:text-2xl">
        {locale === 'tr' ? 'Hız Yarışı' : 'Speed Challenge'}
      </h1>
      <p class="mt-3 text-xs text-green-600">
        {locale === 'tr'
          ? 'Rastgele kelimelerle hız yarışı yapın. Canlı WPM grafiği ve klavye rehberi ile.'
          : 'Race through random words with a live WPM graph and keyboard guide.'}
      </p>
    </div>

    <SpeedChallenge locale={locale} client:only="react" />
  </Container>
</PortfolioLayout>

---
import { getLocaleFromUrl, t, getLocalePath } from '@/i18n'

const locale = getLocaleFromUrl(Astro.url)
const path = Astro.url.pathname

// Build switch-language URL preserving current page
const basePath = locale === 'en' ? path.replace(/^\/en(\/|$)/, '/') : path
const switchLocalePath = locale === 'en' ? (basePath || '/') : `/en${basePath === '/' ? '/' : basePath}`

// Detect zone from URL
const currentZone = path.includes('/lab/vim') ? 'vim'
  : path.includes('/lab/typing') ? 'typing'
  : path.includes('/lab') ? 'dashboard'
  : null

// Zone-specific active colors
const zoneActiveClass: Record<string, string> = {
  vim: 'bg-cyan-500/10 text-cyan-400 text-glow-cyan',
  typing: 'bg-amber-500/10 text-amber-400 text-glow-amber',
  dashboard: 'bg-cyan-500/10 text-cyan-400 text-glow-cyan',
}

const navItems = [
  { href: getLocalePath(locale, '/'), label: '~/' },
  { href: getLocalePath(locale, '/about'), label: '/about' },
  { href: getLocalePath(locale, '/lab'), label: '/lab' },
]
---

<header class="sticky top-0 z-50 flex-none no-print border-b border-green-900/30 bg-black/80 backdrop-blur-md" data-section="header">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4">
      <!-- Logo -->
      <a
        href={getLocalePath(locale, '/')}
        class="group flex items-center gap-2 text-glow-cyan"
      >
        <span class="text-cyan-500">$</span>
        <span class="font-bold text-cyan-400 transition group-hover:text-cyan-300">aburakt</span>
        <span class="cursor-blink text-green-600"></span>
      </a>

      <!-- Nav -->
      <nav class="hidden items-center gap-1 md:flex">
        {navItems.map((item) => {
          const isActive = path === item.href ||
            (item.href !== getLocalePath(locale, '/') && path.startsWith(item.href))

          let activeClass = 'bg-green-500/10 text-green-400 text-glow'
          if (isActive && currentZone && zoneActiveClass[currentZone]) {
            activeClass = zoneActiveClass[currentZone]
          }

          return (
            <a
              href={item.href}
              class:list={[
                'rounded px-3 py-1.5 text-xs transition hover-glitch',
                isActive
                  ? activeClass
                  : 'text-green-600 hover:bg-green-500/5 hover:text-green-400',
              ]}
            >
              {item.label}
            </a>
          )
        })}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-3">
        <button
          onclick="document.dispatchEvent(new CustomEvent('vim:search'))"
          class="rounded border border-green-900/30 px-2 py-1 text-xs text-green-600 transition hover:border-green-500/50 hover:text-green-400"
          title="Search (/ or :)"
          aria-label="Search"
        >
          >_
        </button>
        <a
          href={switchLocalePath}
          class="rounded border border-green-900/30 px-2 py-1 text-xs text-green-600 transition hover:border-green-500/50 hover:text-green-400"
          title={`gl — ${t(locale, 'lang.switch')}`}
        >
          {t(locale, 'lang.switch')}
        </a>
      </div>
    </div>

    <!-- Mobile nav -->
    <nav class="flex gap-1 overflow-x-auto pb-3 md:hidden">
      {navItems.map((item) => {
        const isActive = path === item.href || (item.href !== getLocalePath(locale, '/') && path.startsWith(item.href))

        let activeClass = 'bg-green-500/10 text-green-400'
        if (isActive && currentZone && zoneActiveClass[currentZone]) {
          activeClass = zoneActiveClass[currentZone]
        }

        return (
          <a
            href={item.href}
            class:list={[
              'whitespace-nowrap rounded px-2 py-1 text-xs transition',
              isActive ? activeClass : 'text-green-600 hover:text-green-400',
            ]}
          >
            {item.label}
          </a>
        )
      })}
    </nav>
  </div>
</header>
